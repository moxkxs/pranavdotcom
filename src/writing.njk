---
layout: base.njk
title: Writing
permalink: /writing.html
---
<h2 class="page-title">Writing</h2>

<p class="intro">
    Essays, notes, and musings spanning computer science, markets, and&nbsp;more 
</p>

<div class="separator"></div>

{%- set visiblePosts = writing | visible | sortByDate -%}
{%- set allTags = writing | visible | uniqueTags -%}

{% if allTags.length > 0 %}
<div id="tag-filters" class="tag-filters">
    <button class="tag-filter active" data-tag="all">all</button>
    {%- for tag in allTags %}
    <button class="tag-filter" data-tag="{{ tag }}">{{ tag }}</button>
    {%- endfor %}
</div>
{% endif %}

<section class="blog-posts">
    <div id="all-posts-list">
        {%- for post in visiblePosts %}
        <article class="post-entry" data-tags="{{ post.tags | join(',') if post.tags else '' }}">
            <a href="/posts/{{ post.slug }}.html" class="post-link">
                <h3 class="post-title">{{ post.title }}</h3>
                <p class="post-date">{{ post.date | postDate }}</p>
                {% if post.tags and post.tags.length %}
                <div class="post-tags">
                    {%- for tag in post.tags %}
                    <span class="post-tag">{{ tag }}</span>
                    {%- endfor %}
                </div>
                {% endif %}
                <p class="post-summary">{{ post.summary }}</p>
            </a>
        </article>
        {%- endfor %}
    </div>
</section>

<script>
(function () {
    var tagContainer = document.getElementById('tag-filters');
    if (!tagContainer) return;
    var articles = document.querySelectorAll('.post-entry[data-tags]');

    tagContainer.addEventListener('click', function (e) {
        var btn = e.target.closest('.tag-filter');
        if (!btn) return;
        var tag = btn.dataset.tag;

        tagContainer.querySelectorAll('.tag-filter').forEach(function (b) {
            b.classList.remove('active');
        });
        btn.classList.add('active');

        articles.forEach(function (article) {
            if (tag === 'all') {
                article.style.display = '';
            } else {
                var tags = article.dataset.tags.split(',');
                article.style.display = tags.indexOf(tag) !== -1 ? '' : 'none';
            }
        });
    });
})();
</script>
