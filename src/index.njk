<div class="separator"></div>

<section class="recent-posts">
    <h3 class="section-heading">
        <span class="reading-indicator active"></span>
        Recent Writing
    </h3>
    <div id="recent-posts-list">
        {%- set visiblePosts = writing | visible | sortByDate -%}
        {%- for post in visiblePosts | batch(3) | first -%}
        <article class="post-entry">
            <a href="/writeups/{{ post.slug }}" class="post-link-row">
                <span class="post-row-title">{{ post.title }}</span>
                <span class="post-row-line"></span>
                <span class="post-row-date">{{ post.date | shortDate }}</span>
            </a>
        </article>
        {%- endfor -%}
    </div>

    <div class="all-posts-link">
        <a href="/writing">all posts &#8594;</a>
    </div>
</section>
